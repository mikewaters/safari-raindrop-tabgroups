{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "bookmark-index",
  "title": "Bookmark Index",
  "description": "Match the current browser URL against your bookmark collections",
  "icon": "extension-icon.png",
  "author": "mike",
  "categories": ["Productivity"],
  "license": "MIT",
  "commands": [
    {
      "name": "match-url",
      "title": "Match URL",
      "subtitle": "Bookmark Index",
      "description": "Get the URL from the frontmost browser and find matching bookmark collections",
      "mode": "view",
      "context": ["browser"],
      "keywords": ["safari", "chrome", "arc", "browser", "tab", "url", "bookmark", "collection", "match"],
      "arguments": [
        {
          "name": "hint",
          "type": "text",
          "required": false,
          "placeholder": "Hint (optional)"
        }
      ]
    }
  ],
  "preferences": [
    {
      "name": "openrouterApiKey",
      "type": "password",
      "required": true,
      "title": "OpenRouter API Key",
      "description": "Your OpenRouter API key for LLM-based URL matching",
      "placeholder": "sk-or-v1-..."
    },
    {
      "name": "binaryPath",
      "type": "textfield",
      "required": false,
      "title": "bookmark-index Path",
      "description": "Path to the bookmark-index binary",
      "default": "/Users/mike/.local/bin/bookmark-index",
      "placeholder": "/Users/mike/.local/bin/bookmark-index"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.70.0",
    "@raycast/utils": "^1.13.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.8",
    "@types/node": "20.8.10",
    "@types/react": "18.2.27",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
