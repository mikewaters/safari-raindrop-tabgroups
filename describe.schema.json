{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/mikewaters/safari-tabgroups/describe.schema.json",
  "title": "Describe Tab Group",
  "description": "Output of describe-tabgroup: Collection Card data for a tab group.",
  "oneOf": [
    {
      "description": "Single group output (without --all).",
      "$ref": "#/definitions/GroupCard"
    },
    {
      "description": "All groups output (with --all). Object keyed by group name.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/GroupCard"
      },
      "minProperties": 1
    }
  ],
  "definitions": {
    "GroupCard": {
      "oneOf": [
        { "$ref": "#/definitions/ParsedCard" },
        { "$ref": "#/definitions/RawCard" }
      ]
    },
    "ParsedCard": {
      "type": "object",
      "description": "Successfully parsed Collection Card for a tab group.",
      "required": ["definition", "includes", "keyphrases", "representative_entities"],
      "additionalProperties": false,
      "properties": {
        "definition": {
          "type": "string",
          "minLength": 200,
          "description": "Semantic definition of what belongs in this collection."
        },
        "includes": {
          "type": "array",
          "description": "Examples or rules describing what this collection includes.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 3,
          "maxItems": 8
        },
        "excludes": {
          "type": "array",
          "description": "Optional true non-matches for this collection. Prefer an empty array when the boundary is fuzzy.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 0,
          "maxItems": 3
        },
        "keyphrases": {
          "type": "array",
          "description": "Lowercased keyphrases associated with this collection.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 5,
          "maxItems": 12
        },
        "representative_entities": {
          "type": "array",
          "description": "Representative entities, domains, products, or proper nouns.",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 3,
          "maxItems": 10
        }
      }
    },
    "RawCard": {
      "type": "object",
      "description": "Fallback when the LLM response could not be parsed as JSON.",
      "required": ["_raw"],
      "additionalProperties": false,
      "properties": {
        "_raw": {
          "type": "string",
          "description": "The raw LLM response text."
        }
      }
    }
  }
}
